{
  "adjacent_annotations_slack": "[\\. \\-]?[\\. ]?",
  "resolve_overlap_strategy": {
    "attributes": [
      "priority",
      "length"
    ],
    "ascending": [
      false,
      false
    ]
  },
  "redactor_open_char": "[",
  "redactor_close_char": "]",
  "annotators": {
    "prefix_with_initial": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "prefix+initial",
        "skip": [
          "."
        ],
        "pattern": [
          {
            "lookup": "prefix"
          },
          {
            "or": [
              {
                "lookup": "initial"
              },
              {
                "is_initials": true
              }
            ]
          }
        ]
      }
    },
    "prefix_with_interfix": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "prefix+interfix+name",
        "skip": [
          "."
        ],
        "pattern": [
          {
            "lookup": "prefix"
          },
          {
            "lookup": "interfix"
          },
          {
            "like_name": true
          }
        ]
      }
    },
    "prefix_with_name": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "prefix+name",
        "skip": [
          "."
        ],
        "pattern": [
          {
            "lookup": "prefix"
          },
          {
            "and": [
              {
                "like_name": true
              },
              {
                "neg_lookup": "whitelist"
              }
            ]
          }
        ]
      }
    },
    "interfix_with_name": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "interfix+last_name",
        "skip": [],
        "pattern": [
          {
            "lookup": "interfix"
          },
          {
            "and": [
              {
                "lookup": "interfix_surname"
              },
              {
                "neg_lookup": "whitelist"
              }
            ]
          }
        ]
      }
    },
    "initial_with_name": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "initial+name",
        "skip": [
          "."
        ],
        "pattern": [
          {
            "lookup": "initial"
          },
          {
            "and": [
              {
                "like_name": true
              },
              {
                "neg_lookup": "whitelist"
              },
              {
                "neg_lookup": "prefix"
              }
            ]
          }
        ]
      }
    },
    "initial_interfix": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "names",
      "args": {
        "tag": "initial+interfix+name",
        "skip": [
          "."
        ],
        "pattern": [
          {
            "lookup": "initial"
          },
          {
            "lookup": "interfix"
          },
          {
            "like_name": true
          }
        ]
      }
    },
    "first_name_lookup": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "names",
      "args": {
        "tag": "first_name",
        "overlapping": true,
        "lookup_values": "first_name"
      }
    },
    "surname_lookup": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "names",
      "args": {
        "tag": "last_name",
        "overlapping": true,
        "lookup_values": "surname"
      }
    },
    "patient_name": {
      "annotator_type": "belgian_deduce.annotator.PatientNameAnnotator",
      "group": "names",
      "args": {
        "tag": "_"
      }
    },
    "metadata_entities": {
      "annotator_type": "belgian_deduce.annotator.MetadataEntityAnnotator",
      "args": {
        "tag": "_",
        "priority": 2
      }
    },
    "name_context": {
      "annotator_type": "belgian_deduce.annotator.ContextAnnotator",
      "group": "names",
      "args": {
        "iterative": true,
        "pattern": [
          {
            "name": "interfix_right",
            "direction": "right",
            "pre_tag": [
              "initial",
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person"
            ],
            "tag": "{tag}+interfix+last_name",
            "skip": [
              ".",
              "-"
            ],
            "pattern": [
              {
                "lookup": "interfix"
              },
              {
                "like_name": true
              }
            ]
          },
          {
            "name": "initial_left",
            "direction": "left",
            "pre_tag": [
              "initial",
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person",
              "interfix"
            ],
            "tag": "initial+{tag}",
            "skip": [
              "."
            ],
            "pattern": [
              {
                "lookup": "initial"
              }
            ]
          },
          {
            "name": "initial_right_dotted",
            "direction": "right",
            "pre_tag": [
              "prefix",
              "initial",
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person",
              "interfix"
            ],
            "tag": "{tag}+initial",
            "skip": [],
            "pattern": [
              {
                "lookup": "initial"
              },
              {
                "equal": "."
              }
            ]
          },
          {
            "name": "initial_right",
            "direction": "right",
            "pre_tag": [
              "prefix",
              "initial",
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person",
              "interfix"
            ],
            "tag": "{tag}+initial",
            "skip": [],
            "pattern": [
              {
                "lookup": "initial"
              }
            ]
          },
          {
            "name": "naam_left",
            "direction": "left",
            "pre_tag": [
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person"
            ],
            "tag": "name+{tag}",
            "skip": [
              "-"
            ],
            "pattern": [
              {
                "and": [
                  {
                    "like_name": true
                  },
                  {
                    "neg_lookup": "whitelist"
                  },
                  {
                    "neg_lookup": "prefix"
                  }
                ]
              }
            ]
          },
          {
            "name": "naam_right",
            "direction": "right",
            "pre_tag": [
              "prefix",
              "initial",
              "name",
              "first_name",
              "last_name",
              "initial_patient",
              "first_name_patient",
              "last_name_patient",
              "initial_person",
              "first_name_person",
              "last_name_person",
              "interfix"
            ],
            "tag": "{tag}+name",
            "skip": [
              "-"
            ],
            "pattern": [
              {
                "and": [
                  {
                    "like_name": true
                  },
                  {
                    "neg_lookup": "whitelist"
                  },
                  {
                    "neg_lookup": "prefix"
                  }
                ]
              }
            ]
          },
          {
            "name": "prefix_left",
            "direction": "left",
            "pre_tag": [
              "prefix",
              "initial",
              "name",
              "first_name",
              "last_name",
              "first_name_patient",
              "last_name_patient",
              "interfix"
            ],
            "tag": "prefix+{tag}",
            "skip": [
              "."
            ],
            "pattern": [
              {
                "and": [
                  {
                    "lookup": "prefix"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "eponymous_disease": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "names",
      "args": {
        "lookup_values": "eponymous_disease",
        "tag": "pseudo_name",
        "overlapping": true
      }
    },
    "placename": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "locations",
      "args": {
        "lookup_values": "placename",
        "overlapping": true,
        "tag": "location"
      }
    },
    "street_pattern": {
      "annotator_type": "belgian_deduce.annotator.TokenPatternAnnotator",
      "group": "locations",
      "args": {
        "pattern": [
          {
            "re_match": "[A-Z][a-z]+(baan|bolwerk|dam|dijk|dreef|drf|dyk|gr|gracht|hf|hof|kade|laan|ln|markt|mrkt|pad|park|pd|plantsoen|plein|pln|plnts|prk|singel|sngl|st|steeg|stg|str|straat|weg|wg)$"
          }
        ],
        "tag": "street",
        "priority": 1
      }
    },
    "street_lookup": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "locations",
      "args": {
        "lookup_values": "street",
        "overlapping": true,
        "tag": "street",
        "priority": 1
      }
    },
    "housenumber": {
      "annotator_type": "belgian_deduce.annotator.ContextAnnotator",
      "group": "locations",
      "args": {
        "iterative": true,
        "pattern": [
          {
            "name": "housenumber_right",
            "direction": "right",
            "pre_tag": [
              "street"
            ],
            "tag": "{tag}+house_number",
            "skip": [],
            "pattern": [
              {
                "re_match": "\\d{1,4}$"
              }
            ]
          },
          {
            "name": "housenumber_housenumberletter_right",
            "direction": "right",
            "pre_tag": [
              "street"
            ],
            "tag": "{tag}+house_number+house_number_letter",
            "skip": [],
            "pattern": [
              {
                "re_match": "\\d{1,4}[a-zA-Z]$"
              }
            ]
          },
          {
            "name": "housenumberletter_right",
            "direction": "right",
            "pre_tag": [
              "house_number"
            ],
            "tag": "{tag}+house_number_letter",
            "skip": [],
            "pattern": [
              {
                "re_match": "[a-zA-Z]$"
              }
            ]
          }
        ]
      }
    },
    "postal_code": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "locations",
      "args": {
        "regexp_pattern": "((?<!\\w)(?:[Bb]-)?\\d{4}(?!\\d))",
        "capturing_group": 1,
        "tag": "location"
      }
    },
    "postbus": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "locations",
      "args": {
        "regexp_pattern": "((?i:(?:bus|postbus|boite\\s+postale|bp))\\s*\\d{1,5}(?:[\\./-]\\d{1,4})?)",
        "tag": "location",
        "pre_match_words": [
          "bus",
          "postbus",
          "boite"
        ]
      }
    },
    "hospital": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "institutions",
      "args": {
        "lookup_values": "hospital",
        "overlapping": true,
        "tag": "hospital",
        "priority": 1
      }
    },
    "institution": {
      "annotator_type": "docdeid.process.MultiTokenLookupAnnotator",
      "group": "institutions",
      "args": {
        "lookup_values": "healthcare_institution",
        "overlapping": true,
        "tag": "healthcare_institution"
      }
    },
    "date_dmy_1": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "dates",
      "args": {
        "regexp_pattern": "(?<!\\d)(([1-9]|0[1-9]|[12][0-9]|3[01])(?P<sep>[-/\\. ])([1-9]|0[1-9]|1[012])(?P=sep)((19|20|\\'|`)?\\d{2}))(?!\\d)",
        "tag": "date",
        "capturing_group": 1
      }
    },
    "date_dmy_2": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "dates",
      "args": {
        "regexp_pattern": "(?i)(?<!\\d)(([1-9]|0[1-9]|[12][0-9]|3[01])[-/\\. ]{,2}(januari|jan|februari|feb|maart|mrt|april|apr|mei|juni|jun|juli|jul|augustus|aug|september|sep|sept|oktober|okt|november|nov|december|dec)[-/\\. ]((19|20|\\'|`)?\\d{2}))(?!\\d)",
        "tag": "date",
        "capturing_group": 1,
        "pre_match_words": [
          "januari",
          "jan",
          "februari",
          "feb",
          "maart",
          "mrt",
          "april",
          "apr",
          "mei",
          "juni",
          "jun",
          "juli",
          "jul",
          "augustus",
          "aug",
          "september",
          "sep",
          "sept",
          "oktober",
          "okt",
          "november",
          "nov",
          "december",
          "dec"
        ]
      }
    },
    "date_ymd_1": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "dates",
      "args": {
        "regexp_pattern": "(?<!\\d)(((19|20|\\'|`)\\d{2})(?P<sep>[-/\\. ])([1-9]|0[1-9]|1[012])(?P=sep)([1-9]|0[1-9]|[12][0-9]|3[01]))(\\D|$)",
        "tag": "date",
        "capturing_group": 1
      }
    },
    "date_ymd_2": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "dates",
      "args": {
        "regexp_pattern": "(?i)(?<!\\d)(((19|20|\\'|`)\\d{2})[-/\\. ]{,2}(januari|jan|februari|feb|maart|mrt|april|apr|mei|juni|jun|juli|jul|augustus|aug|september|sep|sept|oktober|okt|november|nov|december|dec)[-/\\. ]([1-9]|0[1-9]|[12][0-9]|3[01]))(?!\\d)",
        "tag": "date",
        "capturing_group": 1,
        "pre_match_words": [
          "januari",
          "jan",
          "februari",
          "feb",
          "maart",
          "mrt",
          "april",
          "apr",
          "mei",
          "juni",
          "jun",
          "juli",
          "jul",
          "augustus",
          "aug",
          "september",
          "sep",
          "sept",
          "oktober",
          "okt",
          "november",
          "nov",
          "december",
          "dec"
        ]
      }
    },
    "date_year_before_colon": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "dates",
      "args": {
        "regexp_pattern": "(?<!\\d)(((19|20)\\d{2}))(?=:)",
        "tag": "date",
        "capturing_group": 1
      }
    },
    "age": {
      "annotator_type": "belgian_deduce.annotator.RegexpPseudoAnnotator",
      "group": "ages",
      "args": {
        "regexp_pattern": "(?i)(?<![\\d,\\.])((1?\\d?\\d)([\\.,]5)?(-(1?\\d?\\d)([\\.,]5)?)?)([ -](jaar|jarig|jarige|jr))(?!\\w)",
        "pre_pseudo": [
          "<",
          "al",
          "co",
          "controle",
          "de",
          "elke",
          "gedurende",
          "na",
          "nog",
          "ongeveer",
          "over",
          "policontrole",
          "sinds",
          "up",
          "vanaf"
        ],
        "post_pseudo": [
          "aanwezig",
          "gebruikt",
          "geleden",
          "gerookt",
          "gestaakt",
          "gestopt",
          "getrouwd",
          "na",
          "naar",
          "nadien"
        ],
        "pre_match_words": [
          "jaar",
          "jarig",
          "jarige",
          "jr"
        ],
        "tag": "age",
        "capturing_group": 1
      }
    },
    "national_register_number": {
      "annotator_type": "belgian_deduce.annotator.NationalRegisterNumberAnnotator",
      "group": "identifiers",
      "args": {
        "national_number_regexp": "(?<!\\d)((?:\\d{2}[\\s./-]?){3}\\d{3}[\\s./-]?\\d{2})(?!\\d)",
        "capture_group": 1,
        "priority": 100,
        "tag": "national_register_number"
      }
    },
    "identifier": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "identifiers",
      "args": {
        "regexp_pattern": "\\d{7,}",
        "tag": "id"
      }
    },
    "phone": {
      "annotator_type": "belgian_deduce.annotator.PhoneNumberAnnotator",
      "group": "phone_numbers",
      "args": {
        "phone_regexp": "(?<!\\d)(?P<prefix>\\(?(?:(?:0032|\\+32|0))(?P<prefix_code>4\\d{2}|800|90[0-9]|78|[1-9]\\d|2|3|4|9)\\)?)(?P<number>(?:[\\s./-]?\\d){4,8})(?!\\d)",
        "min_digits": 9,
        "max_digits": 10,
        "tag": "phone_number"
      }
    },
    "email": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "email_addresses",
      "args": {
        "regexp_pattern": "(([-a-zA-Z0-9:%._\\+~#=]{1,256})@([-a-zA-Z0-9:%._\\+~#=]{1,256})(\\.)(com|net|org|co|us|uk|nl|be|fr|sp|gov|nu))",
        "tag": "email",
        "pre_match_words": [
          "com",
          "net",
          "org",
          "co",
          "us",
          "uk",
          "nl",
          "be",
          "fr",
          "sp",
          "gov",
          "nu"
        ]
      }
    },
    "url": {
      "annotator_type": "docdeid.process.RegexpAnnotator",
      "group": "urls",
      "args": {
        "regexp_pattern": "((https?:\\/\\/(?:www\\.)?)?([-a-zA-Z0-9:%._\\+~#=]{1,256})(\\.)(com|net|org|co|us|uk|nl|be|fr|sp|gov|nu)(\\b)([():%_\\+.~,]*[-a-zA-Z-0-9#?&/=]+)*)",
        "tag": "url",
        "pre_match_words": [
          "com",
          "net",
          "org",
          "co",
          "us",
          "uk",
          "nl",
          "be",
          "fr",
          "sp",
          "gov",
          "nu"
        ]
      }
    }
  }
}
